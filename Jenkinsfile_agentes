pipeline{
    agent none

    options {
        skipDefaultCheckout(true)
        }  
    stages {       
        stage('Get Code')
        {
            agent any
            steps {
                deleteDir()
                checkout scm
                sh '''
                  whoami
                  hostname
                  ls -la
                  rm -f samconfig.toml
                  wget -O samconfig.toml https://raw.githubusercontent.com/ramirodhen/todo-list-aws-config/refs/heads/production/samconfig.toml
                '''
                stash name:'codigo', includes:'**'
                }
        }
        stage('Deploy') {
          agent { label 'deploynode' }
          steps {
            deleteDir()
            unstash 'codigo'
            sh '''
              whoami
              hostname

              set -e
        
              sam build
              sam validate
        
              sam deploy \
                --config-env production \
                --region us-east-1 \
                --no-confirm-changeset \
                --no-fail-on-empty-changeset
        
              BASE_URL=$(aws cloudformation describe-stacks \
                --stack-name production-todolist-aws \
                --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' \
                --output text \
                --region us-east-1)
        
              echo "export BASE_URL=${BASE_URL}" > env.sh
              chmod +x env.sh
              echo "La URL de la API es: ${BASE_URL}"
            '''
            stash name: 'env', includes: 'env.sh'
          }
        }
        stage('Rest Test') {
          agent { label 'testnode' }
          steps {
            deleteDir()
            unstash 'codigo'
            unstash 'env'
            sh '''
              whoami
              hostname

              set -e
              . ./env.sh
              python3 -m pytest -m readonly --junit-xml=result-int.xml test/integration/todoApiTest.py
            '''
            junit allowEmptyResults: false, testResults:'result-int.xml'
            script {
              if (currentBuild.result == 'UNSTABLE') {
                error("Rest tests fallaron. Abortando build del pipeline.")
              }
            }
          } 
        }
      }
    }