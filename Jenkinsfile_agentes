pipeline{
    agent none

    options {
        skipDefaultCheckout(true)
    }

    stages {
        stage('Get Code')
        {
            agent any
            steps {
                deleteDir()
                checkout scm
                sh 'ls -la'
                stash name:'codigo', includes:'**', useDefaultExcludes: false
            }
        }

        stage('Static Test') {
          agent { label 'testnode' }
          steps {
            deleteDir()
            unstash 'codigo'
            sh '''
              rm -f flake8.out bandit.out
              python3 -m flake8 --exit-zero --format=pylint src > flake8.out || true
              python3 -m bandit -r src -f custom -o bandit.out -ll \
                --msg-template "{abspath}:{line}: [{test_id}] {msg}" || true
              touch bandit.out
            '''
            recordIssues tools: [flake8(name: 'Flake8', pattern: 'flake8.out')]
            recordIssues tools: [pyLint(name: 'Bandit', pattern: 'bandit.out')]
          }
        }

        stage('Deploy') {
          agent { label 'deploynode' }
          steps {
            deleteDir()
            unstash 'codigo'
            sh '''
              set -e

              sam build
              sam validate

              sam deploy \
                --config-env default \
                --region us-east-1 \
                --no-confirm-changeset \
                --no-fail-on-empty-changeset

              BASE_URL=$(aws cloudformation describe-stacks \
                --stack-name staging-todolist-aws \
                --query 'Stacks[0].Outputs[?OutputKey==`BaseUrlApi`].OutputValue' \
                --output text \
                --region us-east-1)

              echo "export BASE_URL=${BASE_URL}" > env.sh
              chmod +x env.sh
              echo "La URL de la API es: ${BASE_URL}"
            '''
            stash name: 'env', includes: 'env.sh'
          }
        }

        stage('Rest Test') {
          agent { label 'testnode' }
          steps {
            deleteDir()
            unstash 'codigo'
            unstash 'env'
            sh '''
              . ./env.sh
              echo "Probando contra: $BASE_URL"

              python3 -m pytest -m "not readonly" --junit-xml=result-int.xml test/integration/todoApiTest.py || true
            '''
            junit allowEmptyResults: true, testResults: 'result-int.xml'

            script {
              if (currentBuild.result == 'UNSTABLE')
                error("Tests fallidos")
            }
          }
        }

        stage('Promote') {
          agent any
          steps {
            deleteDir()
            unstash 'codigo'
            sh '''
              set -e
              git fetch origin
              git checkout -B master origin/master
              git config merge.ours.driver true
              git merge origin/develop --no-edit
              git push origin master
            '''
          }
        }
      }
    }